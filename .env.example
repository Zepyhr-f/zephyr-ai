# LLM 配置
LLM_PROVIDER=anthropic
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_AUTH_TOKEN=<token>
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
ANTHROPIC_MODEL=ark-code-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Embedding 配置
EMBEDDING_PROVIDER=ark
EMBEDDING_MODEL=text-embedding-3-small
ARK_EMBEDDING_API_KEY=<api-key>
ARK_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_ENDPOINT=/embeddings/multimodal
ARK_EMBEDDING_MODEL=<your-ark-embedding-endpoint-id>
EMBEDDING_DIMENSION=2048

# Existing Zephyr infra PostgreSQL/pgvector
# In Docker, zephyr-ai connects through external network infra_default.
# Keep real password only in local .env; do not commit it.
DATABASE_URL=postgresql+asyncpg://zephyr:replace-me@pgsql-pgvector:5432/zephyr_ai

# API
API_HOST=0.0.0.0
API_PORT=8000
ZEPHYR_AI_PORT=8000
LOG_LEVEL=INFO
